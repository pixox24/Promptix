# API
PORT=8787
DATABASE_URL=postgresql://promptix:promptix@localhost:5432/promptix
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# Bootstrap admin (used by seed script only)
ADMIN_BOOTSTRAP_EMAIL=admin@promptix.local
ADMIN_BOOTSTRAP_PASSWORD=change-me

# Aliyun OSS
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_CDN_BASE=
OSS_PUBLIC_BASE_URL=

# Storage: auto uses OSS when configured, otherwise local dev storage
STORAGE_DRIVER=auto
LOCAL_STORAGE_DIR=apps/api/.tmp/uploads
PUBLIC_API_BASE=http://localhost:8787

# Async jobs
JOB_ATTEMPTS=3
WORKER_CONCURRENCY=2

# Configure OSS lifecycle rule: expire prefix temp/ after 7 days

# Optional provider keys (database stores only these environment variable names)
LLM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
IMAGE_API_KEY=
IMAGE_65535_API_KEY=
